#!/usr/bin/env bash
set -euo pipefail

MODEL_NAME="md_v1000.0.0-redwood"
MODEL_URL="https://github.com/agentmorris/MegaDetector/releases/download/v1000.0/${MODEL_NAME}.pt"
MODEL_DIR="models"
IMAGE_SIZE="1280"
DOCKER_PLATFORM="${DOCKER_PLATFORM:-linux/amd64}"

echo "Building Container"
docker build --platform "${DOCKER_PLATFORM}" -t megadetector-onnx .

echo "Downloading MDv1000 Redwood"
mkdir -p "${MODEL_DIR}"
wget -q -c "${MODEL_URL}" -O "${MODEL_DIR}/${MODEL_NAME}.pt"

echo "Converting MDv1000 Redwood Dynamic"
docker run --rm --platform "${DOCKER_PLATFORM}" -v "$(pwd)/${MODEL_DIR}:/home/workspace/models" megadetector-onnx \
    python /home/workspace/yolov5/export.py --img-size "${IMAGE_SIZE}" --img-size "${IMAGE_SIZE}" --dynamic --include onnx --weights "models/${MODEL_NAME}.pt"
mv "${MODEL_DIR}/${MODEL_NAME}.onnx" "${MODEL_DIR}/${MODEL_NAME}-dynamic.onnx"

echo "Converting MDv1000 Redwood ${IMAGE_SIZE}x${IMAGE_SIZE}"
docker run --rm --platform "${DOCKER_PLATFORM}" -v "$(pwd)/${MODEL_DIR}:/home/workspace/models" megadetector-onnx \
    python /home/workspace/yolov5/export.py --img-size "${IMAGE_SIZE}" --img-size "${IMAGE_SIZE}" --include onnx --weights "models/${MODEL_NAME}.pt"
mv "${MODEL_DIR}/${MODEL_NAME}.onnx" "${MODEL_DIR}/${MODEL_NAME}-${IMAGE_SIZE}x${IMAGE_SIZE}.onnx"
